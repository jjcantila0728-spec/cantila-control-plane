# Cantila control plane — example environment configuration.
# Copy to .env and edit: `cp .env.example .env`

# HTTP API port (the Console proxies to this).
PORT=8080

# Node environment.
NODE_ENV=development

# Persistence backend. "memory" needs no infrastructure; "prisma" uses Postgres.
STORE=memory

# Required only when STORE=prisma. Matches the Docker snippet in the README.
DATABASE_URL=postgresql://cantila:cantila@localhost:5432/cantila_control_plane?schema=public

# Enforce API-key auth on write routes (plan §5.4).
#   off (default):  every route is open — fine for local dev.
#   on:             /v1/health and /v1/me stay open; everything else needs
#                   a Bearer token. GET requires any scope; mutating
#                   methods require `deploy` or `admin`; /v1/api-keys
#                   requires `admin`.
# Recommended: ON for any deployment that is reachable from the public
# internet. Off for the in-process demo flow.
CANTILA_REQUIRE_AUTH=false

# Social login (Google + GitHub). When a provider's three vars are set the
# control plane wires the real provider; otherwise it falls back to a stub
# (and the stub refuses logins when NODE_ENV=production).
#
# IMPORTANT for LOCAL dev: set each *_REDIRECT_URI to the localhost callback
#   http://localhost:3000/auth/callback/{google,github}
# and register BOTH the localhost AND the https://cantila.app callbacks in
# each provider's OAuth app settings. The control plane sends opts.redirectUri
# (this env value) on the authorize + token exchange, so it must match one of
# the registered URIs for the environment you're running in.
# CANTILA_GOOGLE_CLIENT_ID=
# CANTILA_GOOGLE_CLIENT_SECRET=
# CANTILA_GOOGLE_REDIRECT_URI=https://cantila.app/auth/callback/google
# CANTILA_GITHUB_CLIENT_ID=
# CANTILA_GITHUB_CLIENT_SECRET=
# CANTILA_GITHUB_REDIRECT_URI=https://cantila.app/auth/callback/github
