// ============================================================
// Cantila — control-plane data model
// The single source of truth for all platform state, in PostgreSQL.
//
// Core invariant: every Project owns its OWN dedicated services —
// see ManagedDatabase, Mailbox and PhoneNumber, each keyed 1:1 by a
// unique projectId. They are created with the project on its first
// deploy and torn down with it. (Plan §4.2 — auto-wired services.)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----- enums -----

enum Plan {
  hobby
  starter
  pro
  agency
  dedicated
}

// Billing health of an account, driven by the dunning state machine
// (plan §8 / §15.2 — src/billing/dunning.ts).
enum BillingStatus {
  active
  past_due
  suspended
  canceled
}

enum Role {
  owner
  admin
  developer
  viewer
}

enum Runtime {
  static
  node
  python
  php
  go
  ruby
  docker
}

enum ProjectType {
  web_app
  static_site
  api
  ai_agent
  worker
  cron
}

enum ProjectStatus {
  provisioning
  building
  live
  sleeping
  crashed
  paused
}

enum Region {
  fsn1
  hel1
  ash
}

enum DeployStatus {
  queued
  building
  live
  failed
  rolled_back
  superseded
}

enum DeployTrigger {
  chat
  git
  cli
  mcp
  upload
}

enum DbEngine {
  postgres
  mysql
  mongodb
  redis
}

enum ServiceStatus {
  provisioning
  active
  sleeping
  error
}

enum EnvScope {
  production
  preview
  all
}

enum DomainKind {
  subdomain
  custom
}

enum ApiKeyScope {
  read
  deploy
  admin
}

enum ActivityKind {
  deploy
  domain
  database
  storage
  git
  config
  key
  alert
  backup
  system
}

enum BackupTrigger {
  manual
  auto_pre_deploy
}

enum MailboxKind {
  personal
  shared
}

// Mail alias routing kinds (plan §4.4 — Cantila Mail aliases). Mirrors
// the Console's existing alias vocabulary.
enum MailAliasKind {
  alias
  forward
  catch_all
  parse
}

// Phone-number classification for the number marketplace (plan §4.5).
enum PhoneNumberType {
  local
  toll_free
  mobile
  short_code
}

// Lifecycle state of a marketplace number.
enum MarketplaceNumberStatus {
  active
  porting
  released
}

// What an inbound call to a number does (plan §4.5 — voice routing).
enum CallRoutingAction {
  forward
  voicemail
  reject
  app_webhook
}

// Which engine an automation Project runs (plan §4.10).
enum AutomationKind {
  n8n
  openclaw
}

// ----- identity & accounts -----

model Account {
  id        String   @id @default(cuid())
  name      String
  handle    String   @unique
  plan      Plan     @default(hobby)
  /// Parent account, when this row is a sub-account under an agency /
  /// reseller (plan §5.5 — white-label). Top-level accounts leave this
  /// null. Loose-typed string FK matches the rest of the account-id
  /// columns in this schema; the cross-account assertion lives at the
  /// ControlPlane layer (`canActOnAccount`).
  parentAccountId      String?
  /// Stripe Customer.id — minted on bootstrap by the Stripe rail
  /// (plan §8 / §15.1). Indexed so the webhook receiver can find the
  /// owning tenant by `customer` payload field.
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  /// Per-tenant Anthropic API key (plan §4.3.1). Plaintext in this column
  /// today; production should encrypt-at-rest with a KMS-backed envelope
  /// before writing. Never echoed in standard API responses — masked at
  /// the ControlPlane boundary.
  anthropicApiKey      String?
  /// Billing health driven by the dunning state machine (plan §8 /
  /// §15.2). Defaults to `active` so existing rows backfill cleanly when
  /// this migration runs — no account is ever silently put in dunning.
  billingStatus      BillingStatus @default(active)
  /// Failed-payment count in the current dunning cycle; 0 when healthy.
  dunningAttempts    Int           @default(0)
  /// Most recent failed payment (null unless in dunning).
  dunningFailedAt    DateTime?
  /// When `past_due` escalates to `suspended` (null unless in dunning).
  dunningGraceEndsAt DateTime?
  /// White-label per-account branding (plan §5.5). Optional — when
  /// absent the Console renders the default Cantila identity. Set by
  /// the account itself or by its agency parent.
  /// Hex colour like `#ff7a18` (validated at the ControlPlane layer).
  brandPrimaryColor  String?
  /// Secondary accent colour, hex. Optional.
  brandAccentColor   String?
  /// Public URL to the brand logo (SVG or PNG). The Console renders
  /// it in the sidebar mark slot when set.
  brandLogoUrl       String?
  /// Display name override for the sidebar / topbar — useful when an
  /// agency wants the workspace chrome to read "Acme Client A" rather
  /// than the legal account name.
  brandDisplayName   String?
  /// Plan §5.5 — white-label billing-rollup. When set, this account
  /// does NOT carry its own Stripe subscription; every charge that
  /// would land on its own subscription (number leases, plan tier
  /// fees, etc.) is routed to the referenced account's subscription
  /// instead. Must point at the agency parent (enforced at the
  /// ControlPlane layer; two-level only, no transitive rollup). Null
  /// for accounts that pay their own bill. Indexed so the future
  /// "show me every sub-account on this agency's bill" view hits.
  billedToAccountId  String?
  createdAt DateTime @default(now())

  memberships        Membership[]
  apiKeys            ApiKey[]
  projects           Project[]
  registrations      DomainRegistration[]
  marketplaceNumbers MarketplaceNumber[]

  @@index([parentAccountId])
  @@index([billedToAccountId])
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String
  passwordHash     String?
  twoFactorEnabled Boolean   @default(false)
  /// The account this user belongs to (plan §5.4) — makes a session a
  /// real, account-scoped API credential. Nullable for legacy rows.
  accountId        String?
  /// ISO timestamp when the user verified their email via the
  /// `email_verify` one-shot token flow (plan §5.4 / v1.18). Nullable;
  /// legacy rows read as unverified.
  emailVerifiedAt  DateTime?
  createdAt        DateTime  @default(now())

  memberships Membership[]
  sessions    Session[]
}

model Membership {
  id        String   @id @default(cuid())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  role      Role     @default(developer)
  createdAt DateTime @default(now())

  @@unique([accountId, userId])
}

// ----- per-user sessions (plan §5.4 — OIDC/SSO auth) -----
//
// A server-side session backing the Console's per-user login. The raw
// token is returned once at login (and held in a cookie); only its
// SHA-256 hash is stored — the same one-time-reveal posture ApiKey uses.
// Additive: the scoped-API-key model is unchanged and keeps working
// alongside this; sessions gate the Console, keys gate the API.

model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  /// The account the session is currently scoped to (plan §18). One User
  /// can belong to many Accounts via `Membership`; this records which one
  /// is active for this session. Null = unscoped (caller has no active
  /// org, e.g. just-signed-in user with no memberships yet).
  currentAccountId String?

  @@index([userId])
}

// ----- invites (plan §5.4 — per-user invite flow) -----
//
// A one-time invite for someone to join an Account at a given role.
// The raw token is returned exactly once at creation and embedded in
// the accept URL; only its SHA-256 hash is persisted — same one-time-
// reveal posture as `ApiKey` and `Session`.
//
// `status` is loose-typed (string) to keep this migration additive — no
// new enum is introduced and an out-of-band sweep can write `expired`
// without a schema change. Valid values: pending / accepted / revoked /
// expired.

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

model Invite {
  id                String        @id @default(cuid())
  accountId         String
  email             String
  role              Role          @default(developer)
  tokenHash         String        @unique
  status            InviteStatus  @default(pending)
  invitedByUserId   String?
  createdAt         DateTime      @default(now())
  expiresAt         DateTime
  acceptedAt        DateTime?
  acceptedByUserId  String?

  @@index([accountId, status])
  @@index([email])
}

model ApiKey {
  id         String      @id @default(cuid())
  account    Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId  String
  name       String
  scope      ApiKeyScope @default(deploy)
  prefix     String
  hashedKey  String      @unique
  lastUsedAt DateTime?
  createdAt  DateTime    @default(now())
}

// ----- projects -----

model Project {
  id        String        @id @default(cuid())
  account   Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  slug      String        @unique
  name      String
  runtime   Runtime
  type      ProjectType   @default(web_app)
  region    Region        @default(fsn1)
  status    ProjectStatus @default(provisioning)
  /// Horizontal scaling (plan §5.2). Default 1/1/1 = single instance,
  /// matching the legacy contract for projects created before this column.
  desiredInstances Int           @default(1)
  minInstances     Int           @default(1)
  maxInstances     Int           @default(1)
  repoUrl       String?
  branch        String?
  autoDeploy    Boolean       @default(false)
  /// Per-project HMAC secret for verifying incoming git webhook payloads.
  /// Set by `connectGit`, returned exactly once, rotated via `rotateWebhookSecret`.
  /// Nullable so projects connected before the migration ran keep working.
  webhookSecret String?
  autoSleep  Boolean       @default(true)
  alwaysOn   Boolean       @default(false)
  vcpu      Int           @default(1)
  memoryMb  Int           @default(1024)
  diskGb    Int           @default(5)
  /// Plan §4.10 — when set, this project is a Cantila Automations
  /// instance. The deploy pipeline drops the right engine container in,
  /// and `/v1/automations/*` reads route off this column.
  automationKind   AutomationKind?
  /// Loose JSON bag the automation surfaces use (engine config, ports,
  /// auth-token rotation state). Stored as JSON so schema doesn't need
  /// to grow with the engine catalog.
  automationConfig Json?
  /// UUID of the corresponding Coolify Application (plan §19). Written
  /// on first deploy through `CoolifyDataPlane`; lets the live data
  /// plane look the project back up across restarts without scanning
  /// the full /applications list. Null on stub-only environments.
  coolifyAppUuid   String?
  createdAt DateTime      @default(now())

  deployments     Deployment[]
  envVars         EnvVar[]
  domains         Domain[]
  buckets         StorageBucket[]
  hostedMailboxes HostedMailbox[]
  mailAliases     MailAlias[]

  // auto-wired services — one of each, private to this project
  database    ManagedDatabase?
  mailbox     Mailbox?
  phoneNumber PhoneNumber?

  // per-project brain & build outputs (plan §4.9 + complete-builder)
  messages ProjectMessage[]
  memory   ProjectMemory?
  assets   ProjectAsset[]

  // Per-account name uniqueness — the URL `/@handle/<name>` resolves on
  // this index. Slug remains globally unique (it is the DNS-facing
  // subdomain). Two accounts may both have a project named "MyApp".
  @@unique([accountId, name])
}

model Deployment {
  id            String        @id @default(cuid())
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  status        DeployStatus  @default(queued)
  trigger       DeployTrigger
  runtime       Runtime
  commitHash    String?
  commitMessage String?
  branch        String?
  /// Set when this deployment is a branch preview (plan §5.1). Lives at
  /// {slug}-{previewBranch}.cantila.app; does not supersede production.
  previewBranch String?
  imageRef      String?
  nodeId        String?
  url           String?
  logs          String[]      @default([])
  durationSec   Int           @default(0)
  createdAt     DateTime      @default(now())
}

// ----- auto-wired services (one per project) -----

model ManagedDatabase {
  id            String        @id @default(cuid())
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String        @unique
  engine        DbEngine      @default(postgres)
  version       String
  region        Region
  status        ServiceStatus @default(provisioning)
  sizeGb        Int           @default(10)
  // connection URI — stored encrypted at rest, never returned in plaintext
  connectionUri String
  createdAt     DateTime      @default(now())
}

model Mailbox {
  id            String        @id @default(cuid())
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String        @unique
  address       String
  sendingDomain String
  smtpHost      String
  smtpUser      String
  // SMTP password — stored encrypted at rest
  smtpPassword  String
  status        ServiceStatus @default(provisioning)
  createdAt     DateTime      @default(now())
}

model PhoneNumber {
  id        String        @id @default(cuid())
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String        @unique
  e164      String        @unique
  region    Region
  status    ServiceStatus @default(provisioning)
  // SMS API key — stored encrypted at rest
  apiKey    String
  /// Capabilities as a comma-separated list, e.g. "sms,mms,voice" (plan §4.5).
  capabilities String @default("sms,mms,voice")
  // Inbound-call routing (plan §4.5). Defaults to voicemail.
  callRoutingAction CallRoutingAction @default(voicemail)
  callRoutingTarget String?
  createdAt DateTime      @default(now())
}

/// An inbound mail message received on one of the project's sending
/// domains (plan §4.4 — two-way mail). Persisted message history; an
/// append-only log keyed by accountId / projectId (no FK relation, same
/// shape as `InboundMessage`), distinct from the bounded in-memory mail
/// event ring which keeps only rollup telemetry.
model InboundMail {
  id                String   @id @default(cuid())
  accountId         String
  projectId         String
  /// The Cantila address the message was delivered to.
  toAddress         String
  /// The external sender's address.
  fromAddress       String
  subject           String
  body              String
  /// MTA-side message id (RFC 5322 Message-ID when present).
  providerMessageId String
  /// The `MailAlias.id` that matched `toAddress`, when one did. Absent
  /// when the message landed directly on a `HostedMailbox` address.
  matchedAliasId    String?
  /// Copy of the alias's `target` at receive time — preserves the audit
  /// trail through alias edits afterward.
  routedTo          String?
  receivedAt        DateTime @default(now())

  @@index([projectId, receivedAt])
  @@index([accountId, receivedAt])
}

/// An inbound SMS message received on a project's phone number (plan
/// §4.5 — two-way SMS). Persisted message history; an append-only log
/// keyed by accountId / projectId (no FK relation, like ActivityEvent),
/// distinct from the bounded in-memory SMS event ring.
model InboundMessage {
  id                String   @id @default(cuid())
  accountId         String
  projectId         String
  /// The Cantila number the message was received on, E.164.
  toE164            String
  /// The external sender, E.164.
  fromE164          String
  body              String
  /// Recognised compliance keyword (stop / start / help), when present.
  keyword           String?
  /// Carrier-side message id.
  providerMessageId String
  receivedAt        DateTime @default(now())

  @@index([projectId, receivedAt])
  @@index([accountId, receivedAt])
}

/// An inbound voice call received on a project's phone number (plan §4.5
/// — two-way voice). Persisted call history; an append-only log keyed by
/// accountId / projectId (no FK relation), the voice counterpart of
/// `InboundMessage`.
model InboundCallRecord {
  id             String   @id @default(cuid())
  accountId      String
  projectId      String
  /// The Cantila number the call came in on, E.164.
  toE164         String
  /// The external caller, E.164.
  fromE164       String
  /// Carrier-side call id.
  providerCallId String
  /// The routing action Cantila applied (forward / voicemail / reject / app_webhook).
  routingAction  String
  receivedAt     DateTime @default(now())

  @@index([projectId, receivedAt])
  @@index([accountId, receivedAt])
}

/// Durable SMS telemetry events (plan §4.5) — the persisted backing for
/// the control plane's in-memory SMS event ring, so SMS deliverability
/// history survives a restart. Append-only; the in-memory ring is bounded
/// and rehydrated from the most recent rows on startup.
model SmsEvent {
  id            String   @id @default(cuid())
  at            DateTime
  kind          String
  projectId     String
  accountId     String
  phoneNumberId String
  fromE164      String
  messageId     String
  toMasked      String

  @@index([at])
  @@index([accountId, at])
}

/// Durable mail telemetry events (plan §4.4) — the persisted backing for
/// the control plane's in-memory mail event ring, so mail deliverability
/// history survives a restart. Append-only; the in-memory ring is bounded
/// and rehydrated from the most recent rows on startup. Same posture as
/// `SmsEvent` above.
model MailEvent {
  id             String   @id @default(cuid())
  at             DateTime
  kind           String
  projectId      String
  accountId      String
  mailboxId      String
  mailboxAddress String
  sendingDomain  String
  messageId      String
  toMasked       String

  @@index([at])
  @@index([accountId, at])
  @@index([sendingDomain, at])
}

/// Durable OTP challenges (plan §4.5) — the persisted backing for the
/// control plane's in-memory challenge map, so an in-flight verification
/// survives a restart. The control-plane TTL sweep prunes expired rows.
/// `codeHash` is a salted SHA-256 — the OTP code itself is never stored.
model OtpChallenge {
  id          String   @id
  projectId   String
  accountId   String
  phone       String
  phoneMasked String
  purpose     String
  codeHash    String
  createdAt   DateTime
  expiresAt   DateTime
  attempts    Int      @default(0)
  status      String

  @@index([createdAt])
}

// ----- networking & config -----

model Domain {
  id        String     @id @default(cuid())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  hostname  String     @unique
  kind      DomainKind @default(subdomain)
  sslActive Boolean    @default(false)
  primary   Boolean    @default(false)
  createdAt DateTime   @default(now())
}

// ----- registrar -----
//
// A domain Cantila has registered on the account's behalf (plan §4.7).
// Separate from `Domain` (which is "this hostname is attached to this
// project"). One Account → many DomainRegistrations.

model DomainRegistration {
  id                  String   @id @default(cuid())
  account             Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId           String
  hostname            String   @unique
  tld                 String
  pricePerYearCents   Int
  expiresAt           DateTime
  whoisPrivacy        Boolean  @default(true)
  autoRenew           Boolean  @default(true)
  attachedProjectId   String?
  createdAt           DateTime @default(now())
}

model EnvVar {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  key       String
  // value — encrypted at rest when `secret` is true
  value     String
  secret    Boolean  @default(false)
  scope     EnvScope @default(all)
  updatedAt DateTime @updatedAt

  @@unique([projectId, key, scope])
}

model StorageBucket {
  id         String   @id @default(cuid())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  name       String   @unique
  region     Region
  publicRead Boolean  @default(false)
  cdn        Boolean  @default(false)
  // Logical counters — production fills these from object-store telemetry.
  objects    Int      @default(0)
  sizeGb     Int      @default(0)
  createdAt  DateTime @default(now())
}

// ----- hosted mailboxes (plan §4.4 — Cantila Mail) -----
//
// A real inbox a person uses (you@yourdomain.com) — distinct from the
// auto-wired transactional `Mailbox` above, which is a project's SMTP
// service. A project can own many hosted mailboxes; they are created and
// removed through the mailbox CRUD endpoints (not the deploy pipeline).

model HostedMailbox {
  id          String        @id @default(cuid())
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  address     String        @unique
  displayName String
  kind        MailboxKind   @default(personal)
  quotaMb     Int           @default(10240)
  usedMb      Int           @default(0)
  status      ServiceStatus @default(provisioning)
  createdAt   DateTime      @default(now())

  @@index([projectId])
}

// ----- mail aliases (plan §4.4 — routing rules) -----
//
// A mail forwarding / alias rule. Mail to `address` is routed to `target`
// by the MTA, with semantics determined by `kind`. Project-scoped — the
// alias's hostname must match the project's sending domain (or be
// `*@<domain>` for catch-all). The real MTA does not exist yet (plan
// §15.2); today this records the rule the future MTA will honor.

model MailAlias {
  id          String        @id @default(cuid())
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  address     String        @unique
  target      String
  kind        MailAliasKind @default(alias)
  active      Boolean       @default(true)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
}

// ----- mail sending-IP pools (plan §4.4 — IP-pool rotation) -----
//
// Account-scoped pools the future MTA reads to decide which sending
// IP a given outbound message rides through. `ips` is a comma-separated
// list of IPv4 addresses (synthetic in the prototype). Exactly one
// pool per account is marked `isDefault` — the CP enforces single-default
// at write time.

enum MailIpPoolKind {
  warmup
  main
  transactional
  marketing
}

model MailIpPool {
  id          String         @id @default(cuid())
  accountId   String
  name        String
  kind        MailIpPoolKind @default(main)
  /// Comma-separated IPv4 list; the real MTA reads from the cloud
  /// allocator and writes back here on resize.
  ips         String         @default("")
  reputation  Int            @default(50)
  active      Boolean        @default(true)
  isDefault   Boolean        @default(false)
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([accountId])
}

/// What kind of node this row represents. `managed` is provisioned and
/// owned by Cantila; `byo` was supplied by a tenant via Bring-Your-Own-VPS
/// (plan §5.5).
enum NodeKind {
  managed
  byo
}

/// Lifecycle of a Node — pending → active → (degraded/offline) → retired.
enum NodeStatus {
  pending
  active
  degraded
  offline
  retired
}

/// A compute node the control plane can schedule workloads on (plan §5.5
/// — Bring-Your-Own-VPS). BYO nodes are enrolled by the tenant via a
/// one-time token; the node-agent on the box presents the raw token to
/// flip the row to `active` and to heartbeat. Account-scoped; loose
/// `accountId` FK (matches `ApiKey.accountId` / `MailIpPool.accountId`).
model Node {
  id                    String     @id @default(cuid())
  accountId             String
  kind                  NodeKind   @default(byo)
  label                 String
  region                String
  host                  String     @default("")
  sshUser               String     @default("root")
  /// SHA-256 hash of the one-time enrollment token. The raw value is
  /// returned exactly once at mint and never persisted.
  enrollmentTokenHash   String
  /// Visible prefix of the enrollment token (e.g. "ctn_a1b2…"). Helps
  /// an operator recognise their own pending token without revealing
  /// the secret.
  enrollmentTokenPrefix String
  publicKeyFingerprint  String?
  capacityInstances     Int        @default(16)
  status                NodeStatus @default(pending)
  reportedInstances     Int?
  reportedLoadPct       Int?
  enrolledAt            DateTime?
  lastHeartbeatAt       DateTime?
  retiredAt             DateTime?
  createdAt             DateTime   @default(now())

  @@index([accountId])
  @@index([enrollmentTokenHash])
}

/// A phone number an account bought through the Cantila SMS number
/// marketplace (plan §4.5). Account-owned, billable, with a lifecycle —
/// distinct from the auto-wired per-project `PhoneNumber`.
model MarketplaceNumber {
  id                String                  @id @default(cuid())
  account           Account                 @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId         String
  e164              String                  @unique
  country           String
  numberType        PhoneNumberType
  /// Capabilities as a comma-separated list, e.g. "sms,mms,voice".
  capabilities      String
  setupPriceCents   Int
  monthlyPriceCents Int
  status            MarketplaceNumberStatus @default(active)
  /// Carrier-side id from the TelephonyProvider.
  providerId        String
  /// Optional project the number is assigned to.
  projectId         String?
  /// Stripe SubscriptionItem id billing the recurring monthly lease.
  stripeSubscriptionItemId String?
  purchasedAt       DateTime                @default(now())
  releasedAt        DateTime?

  @@index([accountId])
}

// ----- A2P/10DLC carrier registration (plan §4.5) -----
//
// Brand + campaign records the operator submits to The Campaign
// Registry via a carrier or aggregator before US A2P SMS is allowed
// at scale. Loose-JSON payload because brand and campaign fields
// differ; the CP enforces required keys per kind at create time.

enum A2pRegistrationKind {
  brand
  campaign
}

enum A2pRegistrationStatus {
  draft
  submitted
  in_review
  approved
  rejected
  hold
}

model A2pRegistration {
  id                     String                @id @default(cuid())
  accountId              String
  kind                   A2pRegistrationKind
  name                   String
  status                 A2pRegistrationStatus @default(draft)
  /// For campaigns — the brand `A2pRegistration.id` they belong to.
  brandRegistrationId    String?
  /// Regulatory metadata (legal name + EIN for brand; use case + sample
  /// messages + opt-in flow for campaign). Stored as JSON so the field
  /// set can grow without a schema change.
  payload                Json
  /// Carrier-side TCR id, once the submission is acknowledged.
  providerRegistrationId String?
  rejectionReason        String?
  createdAt              DateTime              @default(now())
  submittedAt            DateTime?
  resolvedAt             DateTime?

  @@index([accountId, kind])
  @@index([accountId, status])
}

// ----- data plane -----

// ----- activity feed -----
//
// Every mutating operation in the ControlPlane records a row here. The
// Console reads it for the dashboard activity widget and the /activity
// page (plan §4.8).

model ActivityEvent {
  id             String       @id @default(cuid())
  accountId      String
  kind           ActivityKind
  title          String
  detail         String
  projectId      String?
  // Plan §5.5 — white-label audit. Only present when an agency
  // parent took the action against a sub-account (actor ≠ target).
  // Legacy rows backfill to NULL — meaning "the account itself".
  actorAccountId String?
  at             DateTime     @default(now())

  @@index([accountId, at])
  @@index([actorAccountId])
}

// ----- agent brain journal (plan §4.9 — continuous learning) -----
//
// Durable record of every action the AgentBrain has taken. Replaces the
// brain's in-memory `actions` ring as the source of truth for the
// learning loop's success-rate math — so a process restart doesn't wipe
// what the brain has learned about its own track record.
//
// `verified` advances from "pending" (post-check scheduled) to "ok" /
// "failed" once the verifier runs. Indexed on `at` (descending reads
// for the snapshot) and on `(agent, kind)` (grouping for buildLearnings).

model AgentAction {
  /// Proposal id — natural key; one record per executed proposal. Unique
  /// so updateAgentActionVerification can upsert the post-check result
  /// keyed by it.
  proposalId      String   @id
  agent           String
  kind            String
  title           String
  outcome         String
  detail          String
  verified        String   @default("n_a")
  verifiedAt      DateTime?
  verifyDetail    String?
  resultProjectId String?
  at              DateTime @default(now())

  @@index([at])
  @@index([agent, kind])
}

// ----- backups (plan §5.5) -----
//
// Point-in-time project snapshots — captures the live deployment id at
// the moment of backup plus a copy of every env var, so restore is a
// rollback of the deployment AND a re-application of the configuration
// that was paired with it.

model Backup {
  id                 String        @id @default(cuid())
  projectId          String
  accountId          String
  deploymentId       String
  /// JSON-serialised array of { key, value, secret, scope }. Stored as
  /// JSON so the snapshot survives env-var deletion/edits on the project.
  envVarsJson        Json
  databaseSnapshotId String?
  note               String?
  trigger            BackupTrigger @default(manual)
  createdAt          DateTime      @default(now())

  @@index([projectId, createdAt])
  @@index([accountId, createdAt])
}

// ----- per-project brain & build outputs (complete-builder) -----
//
// Each project keeps its own chat thread + rolling summary + asset
// gallery. The orchestrator reads `ProjectMemory.summary` plus the last
// ~N `ProjectMessage` rows as the prompt context, so subsequent chats
// stay token-cheap (Anthropic prompt cache) while preserving the full
// history persistently. `ProjectAsset` holds every generated image /
// animation / copy artefact, with a workspace-relative path that the
// build pipeline picks up at deploy time.

enum ProjectMessageRole {
  user
  agent
  system
  tool
}

enum ProjectMessageKind {
  message
  op_card
  result
  asset
}

model ProjectMessage {
  id        String              @id @default(cuid())
  project   Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  role      ProjectMessageRole
  /// Specialist agent or skill that emitted this row, when not the user
  /// (e.g. "deploy", "scale", "generate_image", "orchestrator").
  agent     String?
  kind      ProjectMessageKind  @default(message)
  content   String
  /// Free-form bag for op cards: { opKey, status, detail, deploymentId,
  /// assetId, thumbnailUrl, ... }. Renderer reads this to pick the right
  /// card variant.
  metadata  Json?
  createdAt DateTime            @default(now())

  @@index([projectId, createdAt])
}

model ProjectMemory {
  /// One row per project — projectId is both PK and FK.
  projectId               String   @id
  project                 Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Rolling LLM-written summary of the project so far. Acts as the
  /// cached prompt prefix (cache_control: ephemeral) so each new turn
  /// re-uses the same prefix and only pays for the delta.
  summary                 String   @default("")
  /// The most recent ProjectMessage.id collapsed into `summary`. The
  /// summarizer only walks rows newer than this when it next runs.
  lastSummarizedMessageId String?
  /// Approximate token count of `summary` (informational, helps the
  /// Brain panel show how much of the context window the cache eats).
  tokenCount              Int      @default(0)
  updatedAt               DateTime @updatedAt
}

enum ProjectAssetKind {
  image
  icon
  lottie
  css_anim
  video
  copy
  file
}

model ProjectAsset {
  id        String           @id @default(cuid())
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  kind     ProjectAssetKind
  /// Workspace-relative path, e.g. `public/logo.png`. The build pipeline
  /// picks the file up from `runtime/projects/<projectId>/workspace/`.
  path     String
  mimeType String
  width    Int?
  height   Int?
  /// The prompt that produced the asset (when generated). Used by the
  /// AssetGallery so the user can see what was asked for, and by the
  /// orchestrator if a follow-up regenerates with a tweak.
  prompt   String?
  /// Which provider produced it: "stub", "replicate", "anthropic-svg",
  /// "anthropic-lottie", "fal", etc.
  provider String           @default("stub")
  sizeBytes Int             @default(0)
  createdAt DateTime        @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, kind])
}

// ============================================================
// Cantilapay — Phase 0 foundation (plan §25)
//
// The 12th Cantila product surface. A Cantila-owned tenant-facing
// payments platform with a Stripe-shaped API and Adyen for
// Platforms as the underlying rail. Tenant is Merchant of Record
// (Stripe Connect Express/Custom model).
//
// All models are namespaced `Cantilapay*` so they cannot collide
// with Cantila's own billing (which stays on Stripe — see Account
// .stripeCustomerId + src/billing/*). The two products are fully
// separate at the data layer.
//
// Test/live mode is enforced at the API-key layer (the same key
// cannot read both modes). For storage the `mode` column on each
// row records which side it belongs to; queries always include it.
// ============================================================

enum CantilapayAccountStatus {
  // Tenant enabled cantilapay but has not begun KYC.
  created
  // Adyen sub-merchant created; KYC link generated; awaiting tenant.
  onboarding
  // Adyen approved the sub-merchant; can accept live payments.
  active
  // KYC failed or Adyen rejected — tenant cannot accept payments.
  rejected
  // Tenant or admin disabled the sub-merchant.
  disabled
}

enum CantilapayApiKeyKind {
  publishable
  secret
}

enum CantilapayMode {
  test
  live
}

model CantilapayAccount {
  id String @id @default(cuid())
  /// The owning Cantila tenant Account (loose-typed string FK matching
  /// the rest of the schema's accountId columns; cross-account asserts
  /// live in the ControlPlane layer).
  accountId String @unique
  /// Adyen Account Holder id for the test-mode sub-merchant. Null
  /// until onboarding begins. Adyen treats test/live as fully
  /// separate sub-merchants, so two columns rather than a JSON map.
  adyenAccountHolderIdTest String?
  /// Adyen Account Holder id for the live-mode sub-merchant.
  adyenAccountHolderIdLive String?
  status CantilapayAccountStatus @default(created)
  /// Per-transaction platform fee Cantila collects, in basis points
  /// (10000 bps = 100%). Default 50 bps = 0.5%. The fee is split off
  /// at the Adyen Balance Platform layer when each charge clears.
  platformFeeBps Int @default(50)
  /// ISO-3 country code of the sub-merchant (drives Adyen Legal
  /// Entity shape). Null until onboarding begins.
  country String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiKeys           CantilapayApiKey[]
  webhookEndpoints  CantilapayWebhookEndpoint[]
  events            CantilapayEvent[]
  webhookDeliveries CantilapayWebhookDelivery[]
  idempotencyKeys   CantilapayIdempotencyKey[]
  auditLog          CantilapayAuditLog[]
  // Phase 1 — charges.
  customers      CantilapayCustomer[]
  paymentMethods CantilapayPaymentMethod[]
  paymentIntents CantilapayPaymentIntent[]
  refunds        CantilapayRefund[]
  // Phase 2 — subscriptions.
  products      CantilapayProduct[]
  prices        CantilapayPrice[]
  subscriptions CantilapaySubscription[]
  invoices      CantilapayInvoice[]
  // Phase 3 — Connect-equivalent + payouts.
  payouts             CantilapayPayout[]
  balanceTransactions CantilapayBalanceTransaction[]
  // Phase 4 — hosted sessions.
  checkoutSessions      CantilapayCheckoutSession[]
  billingPortalSessions CantilapayBillingPortalSession[]
  // Phase 5 — tax calculations.
  taxCalculations CantilapayTaxCalculation[]

  @@index([accountId])
}

model CantilapayApiKey {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  name String
  kind CantilapayApiKeyKind
  mode CantilapayMode
  /// First chars of the raw key (e.g. "cpk_test_AbCdEf12"). Shown in
  /// lists so the tenant can identify a key without seeing the secret.
  prefix String
  /// SHA-256 hex of the raw key — same one-time-reveal posture as
  /// `ApiKey.hashedKey`. The raw key is returned exactly once on
  /// creation and never persisted.
  hashedKey String @unique
  lastUsedAt DateTime?
  /// When set, the key is revoked and authentication rejects.
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([cantilapayAccountId, mode])
}

model CantilapayWebhookEndpoint {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  url String
  mode CantilapayMode
  /// Comma-separated event types this endpoint subscribes to. "*" = all.
  enabledEvents String @default("*")
  /// HMAC signing secret used to compute the `Cantilapay-Signature`
  /// header on outbound deliveries. Plaintext today; production
  /// should encrypt-at-rest with a KMS-backed envelope before
  /// writing. Returned exactly once at creation.
  signingSecret String
  signingSecretPrefix String
  /// active | disabled — loose-typed to keep the migration additive.
  status String @default("active")
  createdAt DateTime @default(now())
  lastDeliveryAt DateTime?

  deliveries CantilapayWebhookDelivery[]

  @@index([cantilapayAccountId, mode])
}

model CantilapayEvent {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  /// Stripe-shaped event type, e.g. "payment_intent.succeeded",
  /// "account.updated".
  type String
  /// JSON-encoded event payload. Storing as text keeps the schema
  /// simple at the cost of in-DB queries against it; the outbound
  /// deliverer serialises this directly to the wire.
  data String
  createdAt DateTime @default(now())

  deliveries CantilapayWebhookDelivery[]

  @@index([cantilapayAccountId, mode, createdAt])
  @@index([type])
}

model CantilapayWebhookDelivery {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  endpoint   CantilapayWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  endpointId String
  event   CantilapayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String
  /// pending | succeeded | failed_temporary | failed_permanent
  status String @default("pending")
  attempts Int @default(0)
  lastAttemptAt DateTime?
  /// When the retry worker should next pick this delivery up. Null
  /// for terminal states (succeeded / failed_permanent).
  nextAttemptAt DateTime?
  /// HTTP response code from the last attempt; 0 = network error.
  lastResponseCode Int?
  /// First ~512 chars of the response body, for debugging in the
  /// Console webhook log.
  lastResponseBody String?
  createdAt DateTime @default(now())

  @@index([cantilapayAccountId, status])
  @@index([nextAttemptAt])
}

model CantilapayIdempotencyKey {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  /// The `Cantilapay-Idempotency-Key` value the caller presented.
  key String
  mode CantilapayMode
  /// SHA-256 of the request body. A retry that presents the same
  /// idempotency key with a different body is a 400 (same as Stripe).
  requestHash String
  /// Cached response so a retry returns the original response
  /// byte-for-byte rather than re-running the operation.
  responseStatus Int
  responseBody String
  createdAt DateTime @default(now())
  /// TTL — Stripe keeps idempotency results for 24h. A nightly sweep
  /// deletes anything past this.
  expiresAt DateTime

  @@unique([cantilapayAccountId, mode, key])
  @@index([expiresAt])
}

model CantilapayAuditLog {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  /// Dot-namespaced event type, e.g. "cantilapay.account.created",
  /// "cantilapay.api_key.issued", "cantilapay.webhook.delivered".
  type String
  /// Free-form human-readable message for the Console audit list.
  message String
  /// JSON-encoded structured details. Null when nothing structured
  /// to add beyond the message.
  data String?
  /// The cantilapay api key id used (when the action was via API),
  /// null if via Console session or inbound webhook.
  apiKeyId String?
  createdAt DateTime @default(now())

  @@index([cantilapayAccountId, createdAt])
}

// ============================================================
// Cantilapay — Phase 1 (Charges) (plan §25)
//
// One-time payments: Customer, PaymentMethod (PSP-tokenised —
// Cantila never sees PAN), PaymentIntent (Stripe-shape state
// machine), Refund. Mode-partitioned (test/live) at the row
// level via the same `mode` column the Phase 0 tables use.
//
// All amounts are integers in MINOR currency units (cents,
// ören, pence) — matches Stripe + Adyen conventions and rules
// out floating-point rounding bugs.
// ============================================================

enum CantilapayPaymentIntentStatus {
  /// Created but no payment method attached yet — tenant must
  /// either confirm with a method or call /attach.
  requires_payment_method
  /// Has method; waiting for explicit confirm.
  requires_confirmation
  /// Confirmed; Adyen / PSP issued a 3DS challenge or similar.
  /// The tenant-side SDK handles the redirect / completion.
  requires_action
  /// Submitted to PSP; awaiting AUTHORISATION result.
  processing
  /// Authorised but capture is manual; waiting for /capture.
  requires_capture
  /// Captured + cleared.
  succeeded
  /// Cancelled by tenant or PSP before capture.
  canceled
  /// PSP declined or terminal error.
  failed
}

enum CantilapayCaptureMode {
  automatic
  manual
}

enum CantilapayPaymentMethodStatus {
  chargeable
  detached
}

enum CantilapayRefundStatus {
  pending
  succeeded
  failed
}

model CantilapayCustomer {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  /// Optional tenant-side reference (e.g. their own customer id). Unique
  /// per (account, mode) when set so the tenant can hit upsert-by-ref.
  externalRef String?
  email String?
  name String?
  description String?
  /// Free-form bag of tenant metadata. JSON-encoded text; the route layer
  /// limits each value to 500 chars (Stripe's convention).
  metadata String @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentMethods CantilapayPaymentMethod[]
  paymentIntents CantilapayPaymentIntent[]

  @@unique([cantilapayAccountId, mode, externalRef])
  @@index([cantilapayAccountId, mode, createdAt])
}

model CantilapayPaymentMethod {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  customer   CantilapayCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?
  /// Always "card" in Phase 1. Future kinds (ideal, sepa_debit, …) land
  /// in Phase 4. Loose-typed for forward-compat without a schema change.
  type String @default("card")
  /// PSP-side token — Adyen `storedPaymentMethodId` or stub equivalent.
  /// This is what the PSP charges; Cantila never sees PAN. Required even
  /// for the stub so the wire shape matches what tenants integrate against.
  pspToken String
  /// Display-only — for the tenant Console "Saved methods" list.
  cardBrand String?
  cardLast4 String?
  cardExpMonth Int?
  cardExpYear Int?
  status CantilapayPaymentMethodStatus @default(chargeable)
  /// Tenant metadata bag.
  metadata String @default("{}")
  createdAt DateTime @default(now())
  detachedAt DateTime?

  paymentIntents CantilapayPaymentIntent[]

  @@index([cantilapayAccountId, mode])
  @@index([customerId])
}

model CantilapayPaymentIntent {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  customer   CantilapayCustomer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId String?
  paymentMethod   CantilapayPaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  paymentMethodId String?
  /// Amount in MINOR currency units (cents). Always positive.
  amount Int
  /// Amount that has actually been captured. Equals `amount` once
  /// `succeeded`; 0 before capture; partial captures are not Phase 1.
  amountCaptured Int @default(0)
  /// Sum of all refunds against this intent in minor units.
  amountRefunded Int @default(0)
  /// ISO-4217 lowercase, e.g. "usd", "eur".
  currency String
  captureMode CantilapayCaptureMode @default(automatic)
  status CantilapayPaymentIntentStatus @default(requires_payment_method)
  /// Cantila platform fee, in minor units, derived from
  /// CantilapayAccount.platformFeeBps at create time. Stored so a
  /// later fee config change doesn't retroactively reshape past
  /// intents.
  platformFeeAmount Int @default(0)
  description String?
  /// Tenant metadata bag.
  metadata String @default("{}")
  /// PSP-side reference (Adyen `pspReference`) once submitted.
  /// Indexed so inbound webhooks can find the owning intent.
  pspPaymentRef String?
  /// JSON blob the tenant's frontend SDK uses to mount the payment UI
  /// (Adyen Drop-in `sessionData`, or stub equivalent). Null after
  /// terminal state.
  pspSessionData String?
  /// JSON-encoded last-error info (code, declineCode, message). Set
  /// when status flips to `failed`; preserved for tenant debugging.
  lastError String?
  /// Idempotency key the original create-request carried, when present.
  /// Phase 1+ payment-intent retries can dedupe on this in addition to
  /// the generic CantilapayIdempotencyKey table.
  clientIdempotencyKey String?
  confirmedAt DateTime?
  capturedAt DateTime?
  canceledAt DateTime?
  succeededAt DateTime?
  failedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refunds CantilapayRefund[]

  @@index([cantilapayAccountId, mode, status])
  @@index([cantilapayAccountId, mode, createdAt])
  @@index([pspPaymentRef])
  @@index([customerId])
}

model CantilapayRefund {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  paymentIntent   CantilapayPaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
  paymentIntentId String
  amount Int
  currency String
  status CantilapayRefundStatus @default(pending)
  /// Free-form: "duplicate" / "fraudulent" / "requested_by_customer" /
  /// "other". Loose-typed so a tenant can pass anything Stripe-like.
  reason String?
  /// PSP-side refund id (Adyen `pspReference` for the refund event).
  pspRefundRef String?
  lastError String?
  createdAt DateTime @default(now())
  succeededAt DateTime?
  failedAt DateTime?

  @@index([cantilapayAccountId, mode, status])
  @@index([paymentIntentId])
  @@index([pspRefundRef])
}

// ============================================================
// Cantilapay — Phase 2 (Subscriptions) (plan §25)
//
// Stripe-shaped recurring billing: Product, Price, Subscription,
// Invoice, InvoiceItem. The in-process `billing-engine.ts`
// drives the lifecycle (period advance, dunning) without an
// external scheduler — same posture as the delivery worker
// shipped in Phase 0.
//
// All amounts are integers in MINOR currency units (cents).
// ============================================================

enum CantilapayPriceInterval {
  day
  week
  month
  year
}

enum CantilapaySubscriptionStatus {
  /// Created but the first invoice has not been charged successfully yet.
  incomplete
  /// In a trial period — not yet charging.
  trialing
  /// Charging successfully.
  active
  /// Last charge failed; retrying within the dunning schedule.
  past_due
  /// Cancelled by tenant or by dunning terminal.
  canceled
  /// Stripe-shape "left in dunning, not deactivated" — rarely used,
  /// reserved for tenant policy (we default canceled).
  unpaid
}

enum CantilapayInvoiceStatus {
  draft
  open
  paid
  uncollectible
  void
}

model CantilapayProduct {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  name String
  description String?
  active Boolean @default(true)
  /// Tenant metadata.
  metadata String @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prices CantilapayPrice[]

  @@index([cantilapayAccountId, mode])
}

model CantilapayPrice {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  product   CantilapayProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  /// Unit amount in MINOR currency units (cents).
  unitAmount Int
  /// ISO-4217 lowercase, e.g. "usd", "eur".
  currency String
  /// Recurring interval. Phase 2 always sets this; one-time prices
  /// land in a future drop and are gated behind a separate enum value.
  recurringInterval CantilapayPriceInterval
  recurringIntervalCount Int @default(1)
  /// Days of trial when a subscription on this price is created without
  /// an explicit override. 0 = no trial by default.
  trialPeriodDays Int @default(0)
  active Boolean @default(true)
  metadata String @default("{}")
  createdAt DateTime @default(now())

  subscriptions CantilapaySubscription[]

  @@index([cantilapayAccountId, mode])
  @@index([productId])
}

model CantilapaySubscription {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  /// The subscriber. Loose FK because cantilapay customers can be
  /// deleted (intentionally not cascaded — Stripe behaviour).
  customerId String
  /// The current Price the subscription is billed on. A plan-change
  /// rewrites this column (with proration in a future phase).
  price   CantilapayPrice @relation(fields: [priceId], references: [id], onDelete: Restrict)
  priceId String
  /// The default payment method for this subscription. The billing
  /// engine charges THIS method when each renewal invoice opens.
  defaultPaymentMethodId String?
  status CantilapaySubscriptionStatus @default(incomplete)
  /// Start of the currently-billed period (inclusive).
  currentPeriodStart DateTime
  /// End of the currently-billed period (exclusive). When `<= now()`,
  /// the engine tick advances the period and bills the next one.
  currentPeriodEnd DateTime
  /// When trial began (null if no trial).
  trialStart DateTime?
  /// When trial ends (null if no trial). On the engine tick, when
  /// `now >= trialEnd`, the subscription transitions trialing → active
  /// and the engine generates an invoice for the next period.
  trialEnd DateTime?
  /// When true, the subscription cancels at `currentPeriodEnd` instead
  /// of immediately. Default false (Stripe-shape `cancel_at_period_end`).
  cancelAtPeriodEnd Boolean @default(false)
  canceledAt DateTime?
  endedAt DateTime?
  /// Counter of failed renewal-charge attempts in the current dunning
  /// cycle. Reset to 0 when a charge succeeds.
  dunningAttempts Int @default(0)
  /// Set when the engine plans the next dunning retry; consulted by
  /// the tick to decide whether to retry now.
  nextDunningAt DateTime?
  metadata String @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices CantilapayInvoice[]

  @@index([cantilapayAccountId, mode, status])
  @@index([currentPeriodEnd])
  @@index([nextDunningAt])
  @@index([customerId])
}

model CantilapayInvoice {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  /// The owning subscription. Null for one-off invoices (Phase 2 only
  /// produces subscription invoices; the column is forward-compat).
  subscription   CantilapaySubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  subscriptionId String?
  customerId String
  /// Period this invoice covers (inclusive start, exclusive end).
  periodStart DateTime
  periodEnd DateTime
  /// Total in MINOR currency units.
  amountDue Int
  amountPaid Int @default(0)
  currency String
  status CantilapayInvoiceStatus @default(draft)
  /// When the engine finalised the draft and tried the first charge.
  finalizedAt DateTime?
  /// When the invoice was paid.
  paidAt DateTime?
  /// The PaymentIntent created by the engine when charging this invoice.
  paymentIntentId String?
  /// Counter of failed charge attempts.
  attempts Int @default(0)
  /// JSON-encoded last-error info, set when status moves to open with
  /// attempts > 0.
  lastError String?
  metadata String @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CantilapayInvoiceItem[]

  @@index([cantilapayAccountId, mode, status])
  @@index([subscriptionId])
  @@index([customerId])
}

model CantilapayInvoiceItem {
  id String @id @default(cuid())
  invoice   CantilapayInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  /// Amount in MINOR currency units.
  amount Int
  currency String
  description String
  /// Source price (when this item came from a subscription).
  priceId String?
  periodStart DateTime?
  periodEnd DateTime?
  createdAt DateTime @default(now())

  @@index([invoiceId])
}

// ============================================================
// Cantilapay — Phase 3 (Connect-equivalent: payouts + balance) (plan §25)
//
// Payouts settle accumulated balance to the tenant's bank
// account at the PSP. Cantila is the platform; Adyen for
// Platforms (or stub) is the payout rail.
//
// Every money movement that touches the tenant's available
// balance gets a BalanceTransaction row — Stripe's ledger
// shape. Cantila platform fees show up as negative amounts on
// the tenant ledger.
// ============================================================

enum CantilapayPayoutStatus {
  pending
  in_transit
  paid
  failed
  canceled
}

enum CantilapayBalanceTransactionType {
  charge
  refund
  payout
  /// Cantila's per-transaction platform fee, debited from the
  /// tenant's available balance when a charge clears.
  platform_fee
  /// Adjustment — generic catch-all for manual corrections.
  adjustment
}

model CantilapayBalanceTransaction {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  /// Signed amount in MINOR currency units. Positive = credit to
  /// tenant available balance; negative = debit.
  amount Int
  currency String
  type CantilapayBalanceTransactionType
  description String?
  /// Loose-typed source pointers — exactly one set per row.
  sourcePaymentIntentId String?
  sourceRefundId String?
  sourcePayoutId String?
  createdAt DateTime @default(now())

  @@index([cantilapayAccountId, mode, createdAt])
  @@index([sourcePaymentIntentId])
  @@index([sourceRefundId])
  @@index([sourcePayoutId])
}

model CantilapayPayout {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  /// Amount paid out in MINOR currency units. Always positive.
  amount Int
  currency String
  status CantilapayPayoutStatus @default(pending)
  /// When the funds are expected to land in the tenant's bank.
  /// Phase 3 stub schedules T+1 business day (24h ahead).
  arrivalDate DateTime
  /// The window of balance this payout sweeps. Used by the auditor
  /// to reconcile balance transactions against payouts.
  periodStart DateTime
  periodEnd DateTime
  /// PSP-side reference (Adyen Transfer id) once submitted.
  pspPayoutRef String?
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paidAt DateTime?
  failedAt DateTime?

  @@index([cantilapayAccountId, mode, status])
  @@index([arrivalDate])
}

// ============================================================
// Cantilapay — Phase 4 (Hosted Checkout + Billing Portal) (plan §25)
//
// A CheckoutSession is the tenant's entry point for one-off
// checkout flows: tenant calls POST /checkout/sessions, gets back
// a URL or clientSecret, redirects (or embeds) the end-customer
// to the Cantila-branded payment page. On completion the
// session's `complete` action creates the underlying
// PaymentIntent or Subscription.
//
// BillingPortalSession is the equivalent for the end-customer
// self-service flow (manage payment methods, see invoices,
// cancel subscription).
// ============================================================

enum CantilapayCheckoutSessionMode {
  payment
  subscription
  setup
}

enum CantilapayCheckoutSessionStatus {
  open
  complete
  expired
}

enum CantilapayCheckoutUiMode {
  hosted
  embedded
}

enum CantilapayBillingPortalSessionStatus {
  open
  used
  expired
}

model CantilapayCheckoutSession {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  sessionMode CantilapayCheckoutSessionMode
  status CantilapayCheckoutSessionStatus @default(open)
  uiMode CantilapayCheckoutUiMode @default(hosted)
  customerId String?
  /// JSON-encoded array of line items. For payment-mode sessions:
  ///   [{ amount, currency, name, quantity? }, ...]
  /// For subscription-mode:
  ///   [{ priceId, quantity? }, ...]
  lineItems String
  /// Currency on the session (Phase 4 enforces all line items match).
  currency String
  /// Total amount in minor units — sum of items × quantity. Persisted
  /// so the session view can show it without re-parsing items.
  amountTotal Int @default(0)
  successUrl String
  cancelUrl String?
  /// Embedded-mode return URL (the tenant's frontend page that
  /// finalises after the inline Drop-in completes).
  returnUrl String?
  /// Set on complete. Either a payment intent (sessionMode=payment)
  /// or a subscription (sessionMode=subscription).
  paymentIntentId String?
  subscriptionId String?
  /// Cantila-side URL the tenant redirects to (hosted mode). Phase 4
  /// stub gives a placeholder; cantila-console Phase 6 will serve it.
  url String?
  /// Embedded-mode client secret minted server-side; tenant front
  /// uses it to mount Drop-in in their own page.
  clientSecret String?
  expiresAt DateTime
  completedAt DateTime?
  metadata String @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cantilapayAccountId, mode, status])
  @@index([expiresAt])
}

model CantilapayBillingPortalSession {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  customerId String
  returnUrl String?
  status CantilapayBillingPortalSessionStatus @default(open)
  /// Cantila-side URL the tenant redirects to. Phase 4 stub placeholder.
  url String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt DateTime?

  @@index([cantilapayAccountId, mode, status])
  @@index([expiresAt])
}

// ============================================================
// Cantilapay — Phase 5 (Tax calculation) (plan §25)
//
// Stripe-Tax-shape calculation, calc-only. Cantila does NOT
// file — tenant is Merchant of Record and remains responsible
// for filing in their jurisdictions. The live adapter integrates
// Anrok (non-Stripe, SaaS-friendly); the stub returns 0% so
// non-US dev/test paths work without an Anrok account.
// ============================================================

model CantilapayTaxCalculation {
  id String @id @default(cuid())
  cantilapayAccount   CantilapayAccount @relation(fields: [cantilapayAccountId], references: [id], onDelete: Cascade)
  cantilapayAccountId String
  mode CantilapayMode
  /// Pre-tax subtotal in MINOR currency units.
  amount Int
  currency String
  /// ISO-3 country code, e.g. "USA", "DEU".
  customerCountry String
  customerState String?
  customerPostalCode String?
  /// Total tax computed for this calc, in minor units.
  taxAmount Int
  /// Effective rate in basis points (10000 = 100%).
  taxRateBps Int
  /// JSON-encoded array of breakdown lines, per jurisdiction.
  breakdown String
  /// Which provider produced this calc: "stub", "anrok", "taxjar".
  provider String @default("stub")
  /// Optional category hint (e.g. "saas", "physical_goods") the
  /// tenant passes through to influence tax rules.
  productCategory String?
  createdAt DateTime @default(now())

  @@index([cantilapayAccountId, mode, createdAt])
}
